# ─── Banco de dados ───────────────────────────────────────────────────────────
# Gerar senha: openssl rand -base64 32
POSTGRES_USER=atos_logos_user
POSTGRES_PASSWORD=REPLACE_WITH_STRONG_PASSWORD
POSTGRES_DB=atos_logos_prod

# "db" é o nome do serviço Docker — não use localhost em produção
DATABASE_URL="postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@db:5432/${POSTGRES_DB}?schema=public"

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Gerar: openssl rand -base64 48
JWT_SECRET="replace-with-output-of-openssl-rand-base64-48"

# ─── Aplicação ────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000
