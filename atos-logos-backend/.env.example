# Database connection string (PostgreSQL)
DATABASE_URL="postgresql://postgres:password@localhost:5432/atos_logos?schema=public"

# JWT secret for signing tokens.
# REQUIRED. In production the server refuses to boot if this is missing,
# shorter than 32 chars, or left at any of the known weak defaults
# ("secretKey", "secret", "changeme", "your-secret-key-here").
# Generate a strong value with: openssl rand -base64 48
JWT_SECRET="replace-with-output-of-openssl-rand-base64-48"

# Application port (optional, defaults to 3000)
PORT=3000

# NODE_ENV controls security gates (weak-secret rejection, etc).
# Set to "production" when deploying.
NODE_ENV=development
